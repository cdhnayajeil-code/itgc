  "q1-detail-2": "<div><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 46); font-size: 13px; font-weight: 700; white-space-collapse: collapse; font-family: inherit;\">매월 ERP권한 변경내역 내역보고서&nbsp; 작성 /&nbsp;</span><span style=\"background-color: rgb(255, 255, 255); color: rgb(51, 51, 51); font-family: ng, 나눔고딕; white-space-collapse: collapse;\">분기 OS 및 DB, Superuser 계정권한 모니터링 보고&nbsp;</span></div>",
  "q1-review-2": "<br>",
